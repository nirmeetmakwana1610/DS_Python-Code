price = [20000, 30000, 45000, 50000, 55000, 70000]

target = 50000

low = 0
high = len(price) - 1
ans = -1

while low <= high:
    mid = (low + high) 

    if price[mid] >= target:
        ans = mid
        high = mid - 1
    else:
        low = mid + 1

if ans != -1:
    print("Price =", price[ans])
else:
    print("Not Found")
